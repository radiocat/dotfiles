# Gemini API Key
export GEMINI_API_KEY="your_api_key_here"

# Anthropic API Key
export ANTHROPIC_BASE_URL="http://your-gateway-or-proxy-url"
export ANTHROPIC_AUTH_TOKEN="your_auth_token"
export ANTHROPIC_API_KEY="your_api_key"

# Obsidian Vault Path
# WSL2からWindows側を参照する場合は /mnt/c/... の形式
export OBSIDIAN_VAULT_PATH="/mnt/c/Users/xxx/Documents/Vault"
