# --- Path & Core Settings ---
export DOTFILES_DIR="$HOME/dotfiles"
export PATH="$DOTFILES_DIR/scripts:$PATH"

# --- Homebrew Setup (Linux/WSL2 & Mac) ---
# Homebrew のパスを解決し、環境変数をロードします
if [ -d "/home/linuxbrew/.linuxbrew" ]; then
    # Linux / WSL2
    eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
elif [ -d "/opt/homebrew" ]; then
    # Mac (Apple Silicon)
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# マシン固有の設定（APIキーやObsidianパス）を .env.local から読み込む
if [ -f "$DOTFILES_DIR/.env.local" ]; then
    source "$DOTFILES_DIR/.env.local"
fi

# --- Zsh Basic Configuration ---
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000

# 履歴の扱い
setopt HIST_IGNORE_DUPS     # 直前と同じコマンドは記録しない
setopt SHARE_HISTORY        # 履歴を同時実行中のシェル間で共有
setopt HIST_REDUCE_BLANKS   # 余分な空白を削除して記録

# 操作感の向上
setopt AUTO_CD              # ディレクトリ名入力だけでcd
setopt PROMPT_SUBST         # プロンプト内での変数展開を許可
autoload -Uz compinit && compinit # 補完機能の有効化

# --- Plugins (Homebrewで管理) ---
# Homebrewのプレフィックスを取得（WSL2とMac両対応）
HB_PREFIX=$(brew --prefix 2>/dev/null || echo "/home/linuxbrew/.linuxbrew")

# シンタックスハイライトと補完候補の読み込み
[ -f "$HB_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh" ] && source "$HB_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
[ -f "$HB_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ] && source "$HB_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"

# --- Starship Prompt ---
# Gitステータスなどのリッチな情報はStarshipが担当します
if command -v starship &> /dev/null; then
    eval "$(starship init zsh)"
fi

# --- fzf Integration ---
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# --- Aliases ---
# ターミナル基本操作
alias ls='ls -F --color=auto'
alias ll='ls -l'
alias la='ls -lag'
alias ..='cd ..'

# --- EM-Ops: Obsidian & AI ---
if [ -n "$OBSIDIAN_VAULT_PATH" ]; then
    alias cdv='cd "$OBSIDIAN_VAULT_PATH"'
    
    # OS別の Obsidian 起動エイリアス
    if [[ "$(uname)" == "Darwin" ]]; then
        alias ob='open "obsidian://open?path=$(python3 -c "import urllib.parse; print(urllib.parse.quote(\"'$OBSIDIAN_VAULT_PATH'\"))")"'
    elif [[ "$(uname)" == "Linux" && -d "/mnt/c" ]]; then
        alias ob='powershell.exe Start "obsidian://open?path=$(python3 -c "import urllib.parse; print(urllib.parse.quote(\"'$OBSIDIAN_VAULT_PATH'\"))")"'
    fi
fi

# AI Agent
alias genai='python3 $DOTFILES_DIR/scripts/genai.py'