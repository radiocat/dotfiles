# Path
export DOTFILES_DIR="$HOME/dotfiles"
export PATH="$DOTFILES_DIR/scripts:$PATH"

# Load Secret Env
if [ -f "$DOTFILES_DIR/.env.local" ]; then
    source "$DOTFILES_DIR/.env.local"
fi

# Starship Prompt
eval "$(starship init zsh)"

# Aliases
alias gs='git status'
alias ga='git add'
alias gc='git commit'
alias gp='git push'

alias ls='ls -F'
alias ll='ls -l'
alias la='ls -lag'

# エイリアスや追加パスの設定は、変数が存在する場合のみ行う
if [ -n "$OBSIDIAN_VAULT_PATH" ]; then
    # 例：Vaultディレクトリへの移動エイリアス
    alias cdv='cd "$OBSIDIAN_VAULT_PATH"'
    
    # OS別のObsidian起動用エイリアス
    if [[ "$(uname)" == "Darwin" ]]; then
        # Mac: obsidian:// プロトコルを使用
        alias ob='open "obsidian://open?path=$(python3 -c "import urllib.parse; print(urllib.parse.quote(\"'$OBSIDIAN_VAULT_PATH'\"))")"'
    fi
fi

export PATH="$DOTFILES_DIR/scripts:$PATH"
alias genai='python3 $DOTFILES_DIR/scripts/genai.py'

# fzf integration
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
